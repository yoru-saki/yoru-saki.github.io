<head>
  <meta charset="utf-8">
  <script>
    (function(){
      try {
        var savedTheme = window.localStorage && localStorage.getItem("blog-theme");
        var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
        var theme = savedTheme || (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.style.colorScheme = theme;
      } catch (error) {
        document.documentElement.setAttribute("data-theme", "light");
        document.documentElement.style.colorScheme = "light";
      }
    })();
  </script>
  <style>
    html[data-theme="dark"]{color-scheme:dark;background:#101a1f}
    html[data-theme="dark"] body{background:#101a1f}
  </style>
  <title><% if (page.title && page.title !== config.title) { %><%= page.title %> | <% } %><%= config.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="<%= page.description || config.description %>">
  <meta property="og:type" content="<%= page.layout === 'post' ? 'article' : 'website' %>">
  <meta property="og:title" content="<%= page.title || config.title %>">
  <meta property="og:url" content="<%- full_url_for(page.path || '') %>">
  <meta property="og:site_name" content="<%= config.title %>">
  <meta property="og:description" content="<%= page.description || config.description %>">
  <meta property="og:locale" content="zh_CN">
  <meta property="article:author" content="<%= config.author %>">
  <meta name="twitter:card" content="summary">
  <link rel="shortcut icon" href="<%- url_for(theme.favicon) %>">
  <link rel="stylesheet" href="<%- url_for('/css/style.css') %>?v=20260606-hexo-collage10">
</head>
